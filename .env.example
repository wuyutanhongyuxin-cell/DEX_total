# ============================================================
# DEX_total Environment Variables
# Copy to .env and fill in your API credentials
# ============================================================

# --- Telegram Notifications ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- CEX API Keys (Tier 1) ---
BINANCE_API_KEY=
BINANCE_API_SECRET=

OKX_API_KEY=
OKX_API_SECRET=
OKX_PASSPHRASE=

BITGET_API_KEY=
BITGET_API_SECRET=
BITGET_PASSPHRASE=

# --- DEX Keys (Tier 2) ---
LIGHTER_PRIVATE_KEY=
GRVT_PRIVATE_KEY=
GRVT_API_KEY=
HYPERLIQUID_PRIVATE_KEY=

# --- DEX (Tier 2 — public, no keys required) ---
# Nado: All endpoints are public. URLs configured in config/exchanges.yaml.
# NADO_REST_URL=https://gateway.prod.nado.xyz        # optional override
# NADO_ARCHIVE_URL=https://archive.prod.nado.xyz      # optional override
# NADO_WS_URL=wss://gateway.prod.nado.xyz/v1/subscribe  # optional override

# --- DEX Keys (Tier 3) ---
PARADEX_API_KEY=
ASTER_API_KEY=
EDGEX_API_KEY=

# --- DEX (Tier 3 — public, no keys required) ---
# Variational: Public backend (no auth, no Cloudflare). URL in config/exchanges.yaml.
# VARIATIONAL_REST_URL=https://omni-client-api.prod.ap-northeast-1.variational.io  # optional override

# 01.xyz: Public REST API. URL in config/exchanges.yaml.
# O1XYZ_REST_URL=https://zo-mainnet.n1.xyz  # optional override
