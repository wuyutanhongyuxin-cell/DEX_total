# ============================================================
# DEX_total Environment Variables
# Copy to .env and fill in your API credentials
# ============================================================

# --- Telegram Notifications ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- CEX API Keys (Tier 1) ---
# These are REQUIRED — ccxt uses them for authenticated endpoints

BINANCE_API_KEY=
BINANCE_API_SECRET=

OKX_API_KEY=
OKX_API_SECRET=
OKX_PASSPHRASE=

BITGET_API_KEY=
BITGET_API_SECRET=
BITGET_PASSPHRASE=

# --- DEX (Tier 2) ---
# Lighter / GRVT / Hyperliquid / Nado
# All use public REST APIs for data collection — NO API keys required.
# URLs are configured in config/exchanges.yaml.

# --- DEX (Tier 3) ---
# Paradex / Aster / EdgeX / Variational / 01xyz
# All use public REST APIs — NO API keys required.
# URLs are configured in config/exchanges.yaml.
